# Backend Configuration
PORT=4000

# Database (SQLite)
# By default uses relative path: ./data/showcase.sqlite
DATABASE_URL=./data/showcase.sqlite

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Backend public URL (returned in file upload responses, startup logs)
# If not set, defaults to http://localhost:{PORT}
# Used by: Upload controller for file URL generation
# Example: https://api.example.com
BACKEND_PUBLIC_URL=http://localhost:4000

# OAuth Configuration (if using OAuth2 strategy)
# Uncomment and set these if implementing OAuth authentication
# OAUTH_AUTH_URL=https://oauth-provider.com/auth
# OAUTH_TOKEN_URL=https://oauth-provider.com/token
# OAUTH_CLIENT_ID=your_client_id
# OAUTH_CLIENT_SECRET=your_client_secret
# OAUTH_CALLBACK_URL=http://localhost:4000/auth/oauth/callback
