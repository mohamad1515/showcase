# Backend Environment Variables
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# Database
DATABASE_URL=sqlite:./data/showcase.sqlite

# JWT/Auth (when implementing production auth)
# JWT_SECRET=your-secret-key-here
# JWT_EXPIRY=24h

# OAuth2 (for future implementation)
# OAUTH_GOOGLE_ID=your-google-id
# OAUTH_GOOGLE_SECRET=your-google-secret
# OAUTH_GITHUB_ID=your-github-id
# OAUTH_GITHUB_SECRET=your-github-secret

# Frontend Environment Variables (in frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_OAUTH_URL=${NEXT_PUBLIC_API_URL}/auth/oauth

# Optional: OAuth callback URL
# NEXT_PUBLIC_OAUTH_CALLBACK=http://localhost:3001/auth/oauth/callback
